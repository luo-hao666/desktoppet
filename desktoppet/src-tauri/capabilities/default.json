{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "fs:scope",
      "allow": [{"path": "**"}]
    }
  ]
}
